# ============================================================
# Ovwebnotes - 环境变量配置
# 复制此文件为 .env 并根据实际环境修改配置
# cp .env.example .env
# ============================================================

# -------------------- 数据库 --------------------
# PostgreSQL 连接地址 (Docker 环境使用默认值即可)
DATABASE_URL=postgresql://ovwebnotes:ovwebnotes123@postgres:5432/ovwebnotes_db

# -------------------- Redis --------------------
# Redis 连接地址 (Docker 环境使用默认值即可)
REDIS_URL=redis://redis:6379

# -------------------- 服务端口 --------------------
# 后端服务端口
PORT=3000

# -------------------- 文件存储 --------------------
# Obsidian 库挂载路径 (对应 docker-compose.yml 中的卷映射)
VAULT_PATH=/app/vaults

# 上传文件目录
UPLOAD_DIR=./uploads

# 最大上传文件大小 (字节, 默认 10MB)
MAX_FILE_SIZE=10485760

# -------------------- Git --------------------
# Git 仓库地址 (可选，用于远程同步 Obsidian 库)
GIT_REPO_URL=https://github.com/your-repo/obsidian-vault.git

# -------------------- AI 服务 --------------------
# AI 服务接口地址 (可选)
AI_API_URL=http://localhost:3001/api/ai

# -------------------- Meilisearch (可选) --------------------
# 全文检索引擎地址 (取消 docker-compose.yml 中 meilisearch 服务的注释后启用)
# MEILISEARCH_HOST=http://meilisearch:7700
# MEILISEARCH_API_KEY=change_me_to_a_secure_key

# -------------------- PostgreSQL (仅本地开发参考) --------------------
# 以下变量由 docker-compose.yml 中的 postgres 服务使用，通常无需在此处设置
# POSTGRES_DB=obsidian_notes
# POSTGRES_USER=obsidian
# POSTGRES_PASSWORD=obsidian123
